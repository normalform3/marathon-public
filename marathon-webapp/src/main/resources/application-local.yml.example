spring:
  datasource:
    url: jdbc:mysql://localhost:3306/marathon?characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
    username: marathon
    password: marathon
  data:
    redis:
      host: localhost
      port: 6379
      password:
  rabbitmq:
    host: localhost
    port: 5672
    username: marathon
    password: marathon
    virtual-host: /

minio:
  endpoint: http://localhost:9000
  bucketName: marathon
  access-key: minioadmin
  secret-key: minioadmin

jwt:
  secret: replace-with-a-long-random-local-secret
  expire-seconds: 86400
